# AI Manager Skills Platform - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ai_manager_skills

# For backend connection (auto-constructed if using docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:change_me_in_production@localhost:5432/ai_manager_skills

# =============================================================================
# AUTHENTICATION
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change_me_generate_a_secure_random_key

# =============================================================================
# ANTHROPIC API (for conversation analysis)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# =============================================================================
# FRONTEND URLs
# =============================================================================
VITE_API_URL=http://localhost:8000

# =============================================================================
# CORS (comma-separated list of allowed origins)
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# ADMIN (optional, for admin container)
# =============================================================================
ADMIN_SECRET_KEY=admin_change_me_generate_secure_key
VITE_ADMIN_API_URL=http://localhost:8001
